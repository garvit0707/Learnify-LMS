{
  "expo": {
    "name": "Learnify LMS",
    "slug": "learnify-lms",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.learnify.lms"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      },
      "package": "com.learnify.lms",
      "permissions": [
        "NOTIFICATIONS",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366F1"
        }
      ],
      "expo-asset"
    ],
    "scheme": "learnify",
    "experiments": {
      "typedRoutes": true
    }
  }
}
