{
  "expo": {
    "name": "Learnify LMS",
    "slug": "learnify-lms",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/Learnify.png",
    "splash": {
      "image": "./assets/images/Learnify.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.learnify.lms"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Learnify.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.learnify.lms",
      "permissions": [
        "NOTIFICATIONS",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/Learnify.png",
          "color": "#6366F1"
        }
      ],
      "expo-asset"
    ],
    "scheme": "learnify",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a1100b11-58f0-485e-9350-e1db7e24793b"
      }
    },
    "owner": "garvit77"
  }
}
